{
  "ptl_long_waiters": {
    "tone": "focused",
    "processing_states": ["Identifying longest waiters…", "Checking breach exposure…", "Structuring prioritised overview…"],
    "response_template": {
      "title": "Longest waiters — PTL",
      "sections": [
        { "type": "summary",  "text": "Here are the longest-waiting patients currently on the PTL, ranked by total pathway duration." },
        { "type": "table",    "source": "ptl.long_waiters", "columns": ["Patient", "Specialty", "Weeks waiting", "RTT status", "Next milestone", "Priority"] },
        { "type": "insight",  "text": "Highest exposure is in {top_specialty}. {breach_count} patients are at risk of breaching the 18-week standard." },
        { "type": "actions",  "items": ["View full PTL", "Filter by specialty", "Flag for escalation", "Export list"] }
      ]
    },
    "data_sources": ["ptl", "rtt_monitoring"],
    "guardrails": ["no_clinical_advice", "ops_only"],
    "follow_up_prompts": ["Which specialty has the most breach risk?", "Show me patients over 52 weeks", "What are the next milestones for the top 5?"]
  },

  "ptl_overview": {
    "tone": "informational",
    "processing_states": ["Loading patient tracking list…", "Checking pathway positions…", "Building PTL overview…"],
    "response_template": {
      "title": "PTL overview",
      "sections": [
        { "type": "summary",  "text": "Current state of the patient tracking list across all active pathways." },
        { "type": "table",    "source": "ptl.summary", "columns": ["Specialty", "Total on PTL", "Under 18 weeks", "18–52 weeks", "Over 52 weeks", "Clock stops this week"] },
        { "type": "insight",  "text": "{total_active} patients are currently tracked. {high_risk_count} require attention within 7 days." },
        { "type": "actions",  "items": ["Drill into specialty", "Show longest waiters", "View breach exposure", "Export PTL"] }
      ]
    },
    "data_sources": ["ptl", "access_pathways_waiting_list"],
    "guardrails": ["no_clinical_advice", "ops_only"],
    "follow_up_prompts": ["Who is waiting longest?", "How many are breaching RTT?", "Show me cancellations this week"]
  },

  "rtt_breach": {
    "tone": "urgent",
    "processing_states": ["Checking breach thresholds…", "Scanning RTT clock status…", "Quantifying breach exposure…"],
    "response_template": {
      "title": "RTT breach exposure",
