        { "type": "table",    "source": "rtt_monitoring.breaches", "columns": ["Patient", "Specialty", "Weeks on clock", "Clock start", "Expected breach date", "Status"] },
        { "type": "insight",  "text": "Primary breach pressure is in {top_specialty}. Clock data quality issues detected in {dq_issues} records." },
        { "type": "actions",  "items": ["Escalate highest risk", "Validate clock data", "Filter by specialty", "Request capacity"] }
      ]
    },
    "data_sources": ["rtt_monitoring", "breach_tracking", "ptl"],
    "guardrails": ["no_clinical_advice", "ops_only"],
    "follow_up_prompts": ["Validate the clock data on these records", "Which pathways have the highest breach risk?", "What capacity is available to reduce the backlog?"]
  },

